APP_NAME="Zota ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Kolkata
APP_LOCALE=en
APP_URL=http://localhost/zota_erp

APP_TITLE="Zota ERP"
ADMINISTRATOR_USERNAMES=
SHOW_REPAIR_STATUS_LOGIN_SCREEN=true
ALLOW_REGISTRATION=true
ENABLE_RECAPTCHA=false
GOOGLE_RECAPTCHA_KEY=
GOOGLE_RECAPTCHA_SECRET=
DO_NOT_ALLOW_DISPOSABLE_EMAIL=false
ENABLE_GST_REPORT_INDIA=false
ACTIVITY_LOGGER_ENABLED=true
POS_RECENT_TRANSACTIONS_DISPLAY_LIMIT=10

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=zotaerp
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

DROPBOX_ACCESS_TOKEN=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

BACKUP_DISK=local
BACKUP_ARCHIVE_PASSWORD=

ENVATO_PURCHASE_CODE=

OPENAI_API_KEY=
OPENAI_ORGANIZATION=

